{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", "helpers:pinGitHubActionDigests"],
  "enabledManagers": ["github-actions"],
  "prHourlyLimit": 5,
  "prConcurrentLimit": 3,
  "packageRules": [
    {
      "description": "Disable Renovate for runtime version pins",
      "matchDepNames": ["python"],
      "enabled": false
    },
    {
      "description": "All GitHub Actions updates require manual merge after cool-down",
      "matchManagers": ["github-actions"],
      "automerge": false
    }
  ]
}
